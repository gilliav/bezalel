rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // users: each user can read/write only their own document
    match /users/{uid} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    // courses: any authenticated user can read; only admins can write
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // cohorts: any authenticated user can read; no client writes
    match /cohorts/{cohortId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // projects: anyone can read/create; updates/deletes require auth
    match /projects/{projectId} {
      allow read, create: if true;
      allow update, delete: if isAuthenticated();

      // milestones subcollection
      match /milestones/{milestoneId} {
        allow read: if true;
        allow create, update, delete: if isAuthenticated();
      }

      // attachments subcollection
      match /attachments/{attachmentId} {
        allow read, create: if isAuthenticated();
        allow update, delete: if isAuthenticated();
      }
    }

    // milestones collectionGroup query (used by useMilestones hook)
    match /{path=**}/milestones/{milestoneId} {
      allow read: if true;
    }

    // progress: users can only read/write their own progress records
    match /progress/{progressId} {
      allow read, write: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }
  }
}
